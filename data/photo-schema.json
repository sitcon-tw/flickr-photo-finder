{
  "version": "2026-1.0.0",
  "tables": {
    "photos": {
      "export_path": "fixtures/photos.csv",
      "description_zh": "SITCON Flickr 照片索引。正式資料以 Google Sheets 為準，此 schema 也定義 CSV 匯出格式。",
      "reviewed_required_fields": [
        "subject_type",
        "scene_tags"
      ],
      "fields": [
        {
          "name": "photo_id",
          "label_zh": "Flickr 照片 ID",
          "type": "string",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "Flickr 照片 ID，用來避免重複匯入。"
        },
        {
          "name": "photo_url",
          "label_zh": "Flickr 公開頁面",
          "type": "url",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "Flickr 公開頁面，用來回到原始照片確認脈絡。"
        },
        {
          "name": "album_ids",
          "label_zh": "來源相簿 ID",
          "type": "string",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "匯入工具",
          "description_zh": "這張照片曾由哪些 Flickr 相簿匯入或關聯。多值以分號分隔。"
        },
        {
          "name": "image_preview_url",
          "label_zh": "縮圖 URL",
          "type": "url",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "搜尋介面顯示用縮圖。"
        },
        {
          "name": "album_title",
          "label_zh": "相簿名稱",
          "type": "string",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "匯入工具或整理者",
          "description_zh": "Flickr 相簿名稱。若工具暫時抓不到，可以留空。"
        },
        {
          "name": "event_name",
          "label_zh": "活動名稱",
          "type": "string",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "熟悉活動脈絡者",
          "description_zh": "例如 SITCON 年會、SITCON Camp。不確定就留空。"
        },
        {
          "name": "event_year",
          "label_zh": "活動年份",
          "type": "year",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "熟悉活動脈絡者",
          "description_zh": "四位年份，例如 2026。"
        },
        {
          "name": "people_count",
          "label_zh": "照片中的人數",
          "type": "integer",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "AI 或整理者",
          "description_zh": "照片中可辨識的人數估計值。可留空；若無人可填 0，值必須是非負整數。"
        },
        {
          "name": "subject_type",
          "label_zh": "主要視覺主體",
          "type": "taxonomy",
          "taxonomy_key": "subject_type",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "AI 或整理者",
          "description_zh": "照片海初篩用的主要視覺主體粗分類，例如人物、物件、餐食茶點、文字標示、螢幕或空間。只描述主體種類，不描述活動場景、人數規模或用途。"
        },
        {
          "name": "photographer",
          "label_zh": "攝影師署名",
          "type": "string",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "匯入工具或整理者",
          "description_zh": "攝影師署名。SITCON 是 Flickr 帳號擁有者，不等於攝影師。"
        },
        {
          "name": "license",
          "label_zh": "授權資訊",
          "type": "string",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "Flickr 顯示的授權資訊。不確定時留空並使用 needs_review。"
        },
        {
          "name": "scene_tags",
          "label_zh": "場景標籤",
          "type": "taxonomy",
          "taxonomy_key": "scene_tags",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "整理者",
          "description_zh": "照片中看見的事實，例如攤位、會眾、舞台。"
        },
        {
          "name": "mood_tags",
          "label_zh": "氛圍標籤",
          "type": "taxonomy",
          "taxonomy_key": "mood_tags",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "宣傳、設計、整理者",
          "description_zh": "照片帶來的感受，例如熱鬧、專注、青春感。"
        },
        {
          "name": "recommended_uses",
          "label_zh": "建議用途",
          "type": "taxonomy",
          "taxonomy_key": "recommended_uses",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "各組整理者",
          "description_zh": "適合的工作用途，例如社群貼文、贊助提案。"
        },
        {
          "name": "sponsorship_items",
          "label_zh": "贊助品項",
          "type": "taxonomy",
          "taxonomy_key": "sponsorship_items",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "行銷組或熟悉贊助者",
          "description_zh": "對應 CFS 贊助品項，必須對齊 data/sponsorship-items.json。"
        },
        {
          "name": "sponsorship_tags",
          "label_zh": "贊助價值",
          "type": "taxonomy",
          "taxonomy_key": "sponsorship_tags",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "行銷組或熟悉贊助者",
          "description_zh": "贊助價值或佐證用途，例如品牌露出、會眾互動。"
        },
        {
          "name": "orientation",
          "label_zh": "照片方向",
          "type": "taxonomy",
          "taxonomy_key": "orientation",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "設計、整理者",
          "description_zh": "landscape、portrait、square。"
        },
        {
          "name": "has_negative_space",
          "label_zh": "是否有留白",
          "type": "boolean",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "設計、整理者",
          "description_zh": "true 或 false，表示是否有明顯留白可放字。"
        },
        {
          "name": "safe_crop",
          "label_zh": "安全裁切比例",
          "type": "taxonomy",
          "taxonomy_key": "safe_crop",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "設計、整理者",
          "description_zh": "適合裁切的比例，例如 1:1、16:9。"
        },
        {
          "name": "visual_description",
          "label_zh": "畫面描述",
          "type": "text",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "AI 或整理者",
          "description_zh": "1 到 2 句中立的可見畫面描述，用於自然語言找圖輔助。只描述照片中看得到的物件、動作、文字、位置與空間關係，不自行補活動名稱、年份、身份、單位或贊助推論。"
        },
        {
          "name": "public_use_status",
          "label_zh": "公開使用狀態",
          "type": "taxonomy",
          "taxonomy_key": "public_use_status",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "熟悉公開素材風險者",
          "description_zh": "approved、needs_review、avoid。不確定用 needs_review。"
        },
        {
          "name": "priority_level",
          "label_zh": "推薦優先度",
          "type": "taxonomy",
          "taxonomy_key": "priority_level",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "high、normal、low。表示推薦使用優先度，不是照片品質分數。"
        },
        {
          "name": "collections",
          "label_zh": "素材包",
          "type": "string",
          "required": false,
          "multi_value": true,
          "maintainer_zh": "各組整理者",
          "description_zh": "素材包，例如志工招募、贊助提案、網站橫幅。"
        },
        {
          "name": "curation_notes",
          "label_zh": "整理備註",
          "type": "text",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "公開 repo 與正式 Sheets 中仍視為公開資料，不要寫入敏感內部資訊。"
        },
        {
          "name": "curation_status",
          "label_zh": "整理狀態",
          "type": "taxonomy",
          "taxonomy_key": "curation_status",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "unreviewed、ai_labeled、reviewed。精選或封存不放在整理狀態；優先推薦用 priority_level 或 collections，避免推薦用 public_use_status = avoid。"
        }
      ]
    },
    "albums": {
      "export_path": "fixtures/albums.csv",
      "description_zh": "SITCON Flickr 相簿清單與處理狀態。正式資料以 Google Sheets 為準，此 schema 也定義本機 sample/export 格式。",
      "fields": [
        {
          "name": "album_id",
          "label_zh": "Flickr 相簿 ID",
          "type": "string",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "盤點工具",
          "description_zh": "Flickr 相簿 ID，用來避免重複掃描同一本相簿。"
        },
        {
          "name": "album_url",
          "label_zh": "Flickr 相簿 URL",
          "type": "url",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "盤點工具",
          "description_zh": "SITCON Flickr 公開相簿 URL。"
        },
        {
          "name": "album_title",
          "label_zh": "相簿名稱",
          "type": "string",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "盤點工具",
          "description_zh": "Flickr 相簿名稱。"
        },
        {
          "name": "event_name",
          "label_zh": "活動名稱",
          "type": "string",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "整理者可補上的活動脈絡，例如 SITCON 年會、SITCON Camp。"
        },
        {
          "name": "event_year",
          "label_zh": "活動年份",
          "type": "year",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "四位年份，例如 2026。不確定就留空。"
        },
        {
          "name": "photo_count",
          "label_zh": "照片數",
          "type": "integer",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "盤點工具",
          "description_zh": "工具從 Flickr 相簿頁可取得時填入。"
        },
        {
          "name": "last_processed_at",
          "label_zh": "最近處理時間",
          "type": "datetime",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "最近一次掃描或匯入這本相簿的時間。"
        },
        {
          "name": "notes",
          "label_zh": "備註",
          "type": "text",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "整理者",
          "description_zh": "可公開的相簿整理備註，不要寫入敏感資訊。"
        }
      ]
    },
    "import_batches": {
      "export_path": "fixtures/import-batches.csv",
      "description_zh": "相簿匯入批次紀錄。正式資料以 Google Sheets 為準，此 schema 也定義本機 sample/export 格式。",
      "fields": [
        {
          "name": "batch_id",
          "label_zh": "匯入批次 ID",
          "type": "string",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "匯入批次唯一識別，用來追蹤某次相簿處理。"
        },
        {
          "name": "album_id",
          "label_zh": "Flickr 相簿 ID",
          "type": "string",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "對應 albums.album_id。"
        },
        {
          "name": "album_url",
          "label_zh": "Flickr 相簿 URL",
          "type": "url",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "本次匯入來源相簿 URL。"
        },
        {
          "name": "imported_at",
          "label_zh": "匯入時間",
          "type": "datetime",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "本次掃描或匯入完成時間。"
        },
        {
          "name": "operator",
          "label_zh": "操作者",
          "type": "string",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "匯入工具或技術志工",
          "description_zh": "操作者、agent 或執行環境名稱。"
        },
        {
          "name": "source_tool",
          "label_zh": "來源工具",
          "type": "string",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "使用的 repo script、agent 或其他工具。"
        },
        {
          "name": "found_photo_count",
          "label_zh": "相簿照片數",
          "type": "integer",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "本次在相簿頁找到的照片數。"
        },
        {
          "name": "new_photo_count",
          "label_zh": "新增照片數",
          "type": "integer",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "本次候選匯入中尚未存在於 photos 的照片數。"
        },
        {
          "name": "skipped_photo_count",
          "label_zh": "略過照片數",
          "type": "integer",
          "required": true,
          "multi_value": false,
          "maintainer_zh": "匯入工具",
          "description_zh": "因已存在或其他原因略過的照片數。"
        },
        {
          "name": "notes",
          "label_zh": "備註",
          "type": "text",
          "required": false,
          "multi_value": false,
          "maintainer_zh": "匯入工具或技術志工",
          "description_zh": "可公開的匯入備註，不要寫入敏感資訊。"
        }
      ]
    }
  }
}
